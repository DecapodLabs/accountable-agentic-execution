{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decapodlabs.github.io/accountable-agentic-execution/schemas/task.schema.json",
  "type": "object",
  "required": ["schema_version", "task_id", "canonical_intent", "motivation", "constraints", "priorities", "open_questions", "stop_conditions", "acceptance_rubric", "prompt_variants", "clarification_oracle", "starting_repository", "context_available", "complexity_profile", "interruption_concurrency", "exclusion_rules", "evaluation"],
  "properties": {
    "schema_version": {"const": "task-package.v1"},
    "task_id": {"type": "string", "pattern": "^task-[0-9]{2}-"},
    "study_eligibility": {
      "type": "array",
      "items": {"enum": ["walk_away_alignment", "handoff_continuity", "concurrent_fleet", "tool_switch_continuity"]},
      "uniqueItems": true
    },
    "canonical_intent": {"type": "string", "minLength": 1},
    "motivation": {"type": "string", "minLength": 1},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "priorities": {"type": "array", "items": {"type": "string"}},
    "open_questions": {"type": "array"},
    "stop_conditions": {"type": "array", "items": {"type": "string"}},
    "acceptance_rubric": {"type": "string", "minLength": 1},
    "prompt_variants": {"type": "object", "required": ["natural_delegation", "procedural"]},
    "clarification_oracle": {"type": "string", "minLength": 1},
    "starting_repository": {"type": "object", "required": ["source", "commit"]},
    "context_available": {"type": "object", "required": ["conventional", "decapod_governed"]},
    "complexity_profile": {"type": "object", "required": ["empirical_eligible", "required_reasoning"]},
    "interruption_concurrency": {"type": "object"},
    "handoff_checkpoint": {
      "type": "object",
      "properties": {
        "trigger": {"type": "string"},
        "observable_rule": {"type": "string"},
        "conventional_payload": {"type": "array", "items": {"type": "string"}},
        "decapod_payload": {"type": "array", "items": {"type": "string"}}
      }
    },
    "task_graph": {
      "type": "object",
      "properties": {
        "nodes": {"type": "array"},
        "edges": {"type": "array"},
        "overlap_classes": {"type": "array", "items": {"type": "string"}},
        "integration_validation": {"type": "array", "items": {"type": "string"}}
      }
    },
    "exclusion_rules": {"type": "array", "items": {"type": "string"}},
    "evaluation": {"type": "object", "required": ["hidden_evaluator", "validation_commands"]}
  },
  "additionalProperties": true
}
