{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decapodlabs.github.io/accountable-agentic-execution/schemas/run-record.schema.json",
  "type": "object",
  "required": ["schema_version", "kind", "run_id", "task_id", "substrate", "instruction_style", "prompt", "provenance", "outcome"],
  "properties": {
    "schema_version": {"const": "run-record.v2"},
    "kind": {"enum": ["synthetic_fixture", "pilot", "empirical"]},
    "run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "substrate": {"enum": ["conventional", "decapod_governed", "legacy_fixture"]},
    "instruction_style": {"enum": ["natural_delegation", "procedural", "checklist_only", "legacy_fixture"]},
    "prompt": {"type": "object", "required": ["text", "characters", "approx_tokens", "procedural_steps", "named_paths", "named_commands", "named_tests", "implementation_prescriptions"]},
    "provenance": {"type": "object", "required": ["protocol_id", "task_commit", "model", "runtime", "timestamps", "environment", "configuration"]},
    "outcome": {"type": "object", "required": ["task_success", "intent_fidelity", "invalid_completion_claim", "proof_completeness"]}
  },
  "additionalProperties": true
}
